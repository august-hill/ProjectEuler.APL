⍝ Convert to numeric digits
d ← (⍎¨digits) - 0

⍝ Solution: sliding window of 13, compute products, take max
∇ R ← Solve d;n;k;maxp;i;w;p
  n ← ⍴d
  k ← 13
  maxp ← 0
  :For i :In ⍳(n-k+1)
    w ← d[i+⍳k-1]
    p ← ×/w
    :If p > maxp
      maxp ← p
    :EndIf
  :EndFor
  R ← maxp
∇

result ← Solve d
⎕ ← 'Result: ' , ⍕result
